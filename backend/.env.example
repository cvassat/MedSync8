# Required for /api/chat
ANTHROPIC_API_KEY=sk-ant-...

# Optional model/runtime tuning
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096
RAG_TOP_K=4
CHAT_MAX_MESSAGES=50
CHAT_MAX_MESSAGE_CHARS=20000

# Retrieval/indexing
CORPUS_DIR=./corpus
EMBED_BACKEND=openai
OPENAI_API_KEY=sk-...

# Browser/client access
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Cloudflare Access enforcement (set both to enable)
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# Audit logging (set AUDIT_SALT in all non-local deployments)
AUDIT_LOG_PATH=./audit.log
AUDIT_SALT=replace-with-strong-unique-secret
